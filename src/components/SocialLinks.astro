---
import { socials } from "../data/profile";
import Icon from "./Icon.astro";

interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<ul class:list={["socials", className]}>
  {
    socials.map((s) => (
      <li>
        <a
          class="socials__link"
          href={s.href}
          target={s.icon === "email" ? undefined : "_blank"}
          rel={s.icon === "email" ? undefined : "noopener"}
          aria-label={s.label}
          data-email={s.icon === "email" ? s.href.replace("mailto:", "") : undefined}
        >
          <Icon name={s.icon} />
          <span class="socials__label">{s.label}</span>
        </a>
      </li>
    ))
  }
</ul>

<script>
  // Progressive enhancement for the email link. A bare `mailto:` silently does
  // nothing on machines with no registered mail handler (common on Windows /
  // webmail users), so we also copy the address to the clipboard and flash
  // "Copied" feedback. We don't preventDefault — anyone *with* a mail client
  // still gets their compose window as well.
  for (const link of document.querySelectorAll<HTMLAnchorElement>("a[data-email]")) {
    link.addEventListener("click", async () => {
      const email = link.dataset.email;
      const label = link.querySelector<HTMLElement>(".socials__label");
      if (!email || !label || !navigator.clipboard) return;
      try {
        await navigator.clipboard.writeText(email);
        const original = label.textContent;
        label.textContent = "Copied";
        link.setAttribute("data-copied", "");
        window.setTimeout(() => {
          label.textContent = original;
          link.removeAttribute("data-copied");
        }, 1600);
      } catch {
        // Clipboard blocked (e.g. insecure context) — mailto still fires.
      }
    });
  }
</script>

<style>
  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .socials__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    padding: 0.5rem 0.85rem;
    font-size: 0.85rem;
    transition:
      color var(--speed) var(--ease),
      border-color var(--speed) var(--ease),
      background var(--speed) var(--ease);
  }

  .socials__link:hover {
    color: var(--text);
    border-color: var(--border-strong);
    background: var(--bg-elevated);
  }

  .socials__link[data-copied] {
    color: var(--accent);
    border-color: var(--accent);
  }

  .socials__link :global(svg) {
    width: 18px;
    height: 18px;
  }

  .socials__label {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
  }
</style>
