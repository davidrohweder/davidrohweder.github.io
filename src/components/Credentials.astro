---
import { certifications, awards } from "../data/profile";
import SectionHeading from "./SectionHeading.astro";
---

<section class="section reveal" id="recognition" aria-labelledby="recognition-title">
  <div class="container">
    <SectionHeading index="06" title="Certifications & Recognition" id="recognition-title" />

    <div class="creds">
      <div class="creds__col">
        <h3 class="creds__label mono">Certifications</h3>
        <ul class="creds__list">
          {
            certifications.map((c) => (
              <li class="creds__item">
                <div class="creds__main">{c.title}</div>
                <div class="creds__sub mono">
                  {c.issuer} · {c.year}
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="creds__col">
        <h3 class="creds__label mono">Awards</h3>
        <ul class="creds__list">
          {
            awards.map((a) => (
              <li class="creds__item">
                <div class="creds__main">{a.title}</div>
                <div class="creds__sub mono">{a.detail}</div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .creds {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 6vw, 4rem);
  }

  .creds__label {
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 1.25rem;
  }

  .creds__list {
    display: flex;
    flex-direction: column;
  }

  .creds__item {
    padding-block: 0.95rem;
    border-top: 1px solid var(--border);
  }

  .creds__item:first-child {
    border-top: none;
    padding-top: 0;
  }

  .creds__main {
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .creds__sub {
    margin-top: 0.3rem;
    font-size: 0.74rem;
    color: var(--text-faint);
  }

  @media (min-width: 720px) {
    .creds {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
