---

<svg
  class={className}
  width="20"
  height="20"
  viewBox="0 0 24 24"
  fill={isStroked ? "none" : "currentColor"}
  stroke={isStroked ? "currentColor" : "none"}
  stroke-width={isStroked ? 2 : 0}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
