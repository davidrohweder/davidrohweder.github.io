---
import { projects } from "../data/profile";
import SectionHeading from "./SectionHeading.astro";
import Icon from "./Icon.astro";
---

<section class="section reveal" id="projects" aria-labelledby="projects-title">
  <div class="container">
    <SectionHeading index="03" title="Selected Projects" id="projects-title" />

    <ul class="grid">
      {
        projects.map((p) => (
          <li class="card">
            <div class="card__top">
              <h3 class="card__name">{p.name}</h3>
              <span class="card__period mono">{p.period}</span>
            </div>
            {p.context && <p class="card__context mono">{p.context}</p>}

            <p class="card__blurb">{p.blurb}</p>

            <ul class="card__points">
              {p.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>

            <div class="card__foot">
              <ul class="tag-list card__tags">
                {p.stack.map((t) => (
                  <li class="tag">{t}</li>
                ))}
              </ul>
              {p.links && (
                <div class="card__links">
                  {p.links.map((l) => (
                    <a
                      class="card__link"
                      href={l.href}
                      target="_blank"
                      rel="noopener"
                      aria-label={`${p.name} — ${l.label}`}
                    >
                      {l.label}
                      <Icon name="north-east" />
                    </a>
                  ))}
                </div>
              )}
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 1.4rem 1.45rem;
    overflow: hidden;
    transition:
      transform var(--speed) var(--ease),
      border-color var(--speed) var(--ease),
      box-shadow var(--speed) var(--ease);
  }

  /* signature: 1px accent tick grows from the left edge on hover */
  .card::before {
    content: "";
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 220ms var(--ease);
  }

  .card:hover,
  .card:focus-within {
    transform: translateY(-2px);
    border-color: var(--border-strong);
    box-shadow:
      inset 0 1px 0 var(--accent-soft),
      0 10px 30px -18px rgba(0, 0, 0, 0.8);
  }

  .card:hover::before,
  .card:focus-within::before {
    transform: scaleX(1);
  }

  .card__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .card__name {
    font-size: 1.0625rem;
    font-weight: 580;
    letter-spacing: -0.01em;
  }

  .card__period {
    font-size: 0.72rem;
    color: var(--text-faint);
    flex-shrink: 0;
  }

  .card__context {
    margin-top: 0.35rem;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--accent);
  }

  .card__blurb {
    margin-top: 0.7rem;
    color: var(--text);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .card__points {
    margin-top: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .card__points li {
    position: relative;
    padding-left: 1.1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .card__points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 1px;
    background: var(--text-faint);
  }

  .card__foot {
    margin-top: auto;
    padding-top: 1.2rem;
  }

  .card__tags {
    gap: 0.4rem;
  }

  .card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.9rem;
  }

  .card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.03em;
    color: var(--text-muted);
    transition: color var(--speed) var(--ease);
  }

  .card__link :global(svg) {
    width: 14px;
    height: 14px;
    transition: transform var(--speed) var(--ease);
  }

  .card__link:hover {
    color: var(--accent);
  }

  .card__link:hover :global(svg) {
    transform: translate(2px, -2px);
  }

  @media (min-width: 720px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
  }
</style>
